<?xml version="1.0"?>
<ruleset name="GF User Journey">
	<description>PHPCS rules for GF User Journey plugin</description>

	<file>.</file>

	<arg name="extensions" value="php"/>
	<arg name="colors"/>
	<arg value="sp"/>

	<exclude-pattern>vendor/*</exclude-pattern>
	<exclude-pattern>node_modules/*</exclude-pattern>
	<exclude-pattern>includes/*</exclude-pattern>

	<rule ref="WordPress-Extra">
		<!-- Main plugin file can't follow class-* naming convention. -->
		<exclude name="WordPress.Files.FileName.InvalidClassFileName"/>

		<!-- Short array syntax [] is fine on PHP 7.4+. -->
		<exclude name="Universal.Arrays.DisallowShortArraySyntax.Found"/>
	</rule>

	<config name="minimum_supported_wp_version" value="6.3"/>

	<rule ref="WordPress.WP.I18n">
		<properties>
			<property name="text_domain" type="array">
				<element value="gf-user-journey"/>
			</property>
		</properties>
	</rule>
</ruleset>
